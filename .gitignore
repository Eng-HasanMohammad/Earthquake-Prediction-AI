# Byte-compiled / cache
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# Environments
venv/
.venv/
env/

# Data (too large for git — see README for download instructions)
data/raw/*.csv
data/processed/*.csv
!data/raw/.gitkeep
!data/processed/.gitkeep

# Trained model artifacts (regenerate via training scripts/notebooks)
models/*.joblib
models/*.h5
models/*.keras
!models/.gitkeep

# OS / editor
.DS_Store
.vscode/
.idea/

# Jupyter
*.ipynb_checkpoints
